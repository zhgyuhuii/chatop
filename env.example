# Webtop / Selkies 环境变量示例
# 复制为 .env 后修改，docker compose 会自动加载 .env 进行变量替换
# 使用：cp env.example .env && 编辑 .env

# 用户权限
PUID=1000
PGID=1000

# 认证（CUSTOM_USER 同时用于 HTTP 认证和 KDE 面板左下角显示的用户名）
# PASSWORD 同时用于 root/abc 的 su 密码，使 su 命令可用
# ！！必须改成强密码再使用：端口 3001 对外暴露时，此密码=容器 root 权限
CUSTOM_USER=admin
PASSWORD=change-me-to-a-strong-password

# 主机名（设置窗口悬停显示 user@hostname，避免显示容器 ID）
# 如 CUSTOM_HOSTNAME=统御至诚云桌面 则显示 admin@统御至诚云桌面
CUSTOM_HOSTNAME=webtop

# 时区与语言
TZ=Asia/Shanghai
LC_ALL=zh_CN.UTF-8

# 页面标题（浏览器标签）
TITLE=Ubuntu KDE (Custom Selkies)

# Selkies 侧边栏标题与图标
SELKIES_UI_TITLE=Webtop
# 图标：构建时用项目根目录的 logo.png；运行时挂载 ./logo.png 或 ./assets（内含 logo.png）覆盖
DASHBOARD=selkies-dashboard
FILE_MANAGER_PATH=/config/Desktop
SELKIES_FILE_TRANSFERS=upload,download

# 安全加固（true 启用）
# HARDEN_DESKTOP=false
# DISABLE_SUDO=false

# 说明：容器内 GUI 软件中心（PackageKit）不可用，请用终端安装：sudo apt install 软件名

# 应用程序管理：数据从 GitHub 拉取，国内可能需 VPN 或代理；已内置 ghproxy 等镜像作为备用

# KDE 任务栏：已通过 94-kde-panel-center.sh 使图标居中显示；首次需重建镜像并重启容器

# 构建时界面定制：将配置放入 custom-defaults/ 目录，构建后首次启动（空 volume）会自动应用
# 详见 custom-defaults/README.md

# 已内置：openclaw-tool（桌面图标）、WhiteSur GTK 主题与 WhiteSur 图标，首次启动自动应用
# 注意：原 MacVentura-Dark KDE 主题依赖未提供的 *-kde*.zip，已从构建移除；
#       /etc/skel/.config/kdeglobals 仍指向它时 KDE 会回退到默认 Breeze 外观
